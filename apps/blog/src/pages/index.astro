---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BlogGrid from "../components/BlogGrid.astro";
import { listAllPublishedDocuments, getPublicStorageUrl } from "../lib/convex";
import { SITE } from "../lib/config";

import "@elcokiin/ui/styles";
import "../styles/global.css";

const cacheControl = "public, max-age=120, s-maxage=600, stale-while-revalidate=3600";
Astro.response.headers.set("Cache-Control", cacheControl);

const published = await listAllPublishedDocuments();

const posts = await Promise.all(
  published.map(async post => ({
    ...post,
    coverUrl:
      post.coverImageId ? (await getPublicStorageUrl(post.coverImageId)) ?? undefined : undefined,
  })),
);
---

<BaseLayout title={`${SITE.title} · Blog`} description={SITE.description} canonicalPath="/">
  <SiteHeader />
  <main class="container mx-auto px-4 md:px-8 max-w-7xl">
    <section class="hero py-12 md:py-20 max-w-3xl">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 tracking-tight">Published documents, human writing, and clear thought.</h1>
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400">
        A live Astro SSR blog powered by Convex. Inspired by AstroPaper structure and
        elcokiin visual language.
      </p>
    </section>

    <BlogGrid posts={posts as any} />
  </main>
  <SiteFooter />
</BaseLayout>
