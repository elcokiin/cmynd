---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { getPublishedDocumentBySlug, getPublicStorageUrl } from "../../lib/convex";
import { formatPublishedDate } from "../../lib/utils";
import { renderRichContent } from "../../lib/tiptap-render";
import { SITE } from "../../lib/config";

import "../../styles/global.css";

const cacheControl = "public, max-age=300, s-maxage=1800, stale-while-revalidate=7200";
Astro.response.headers.set("Cache-Control", cacheControl);

const slug = Astro.params.slug;

if (!slug) {
  return Astro.redirect("/");
}

const post = await getPublishedDocumentBySlug(slug);

if (!post) {
  return Astro.redirect("/404");
}

const coverUrl = post.coverImageId ? await getPublicStorageUrl(post.coverImageId) : undefined;
const htmlContent = renderRichContent(post.content);

const title = `${post.title} · ${SITE.title}`;
const description = `${post.author.name} · ${formatPublishedDate(post.publishedAt)}`;
const canonicalPath = `/posts/${post.slug}/`;

const r = post.type === "reprint" ? post.reprint : undefined;
const isReprint = r !== undefined;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <SiteHeader />
  <main class="post-main container">
    <article class="post-article">
      {!isReprint && <p class="post-card-meta">{post.author.name} · {formatPublishedDate(post.publishedAt)}</p>}
      <h1>{post.title}</h1>
      {
        isReprint && (
          <div class="reprint-section">
            <div class="reprint-inner">
              {r!.originalTitle && (
                <p class="reprint-field reprint-original-title">
                  {r!.sourceUrl ? (
                    <a href={r!.sourceUrl} target="_blank" rel="noopener noreferrer">
                      {r!.originalTitle}
                      <svg class="external-link-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </a>
                  ) : (
                    <span>{r!.originalTitle}</span>
                  )}
                </p>
              )}
              <p class="reprint-field reprint-author-year">
            {r!.originalAuthor ?  `Autor: ${r!.originalAuthor}` : ''}{r!.originalDate ? ` · ${r!.originalDate}` : ''}
              </p>
              <p class="reprint-field reprint-publisher">
                {post.author.name ?  `Publicado por: ${post.author.name}` : ''} · {formatPublishedDate(post.publishedAt)}
              </p>
              {post.estimatedReadTime && (
                <p class="reprint-field reprint-reading-time">
                  {post.estimatedReadTime} min de lectura
                </p>
              )}
              {r!.translator && (
                <p class="reprint-field reprint-translator">
                  <span class="reprint-label">Traductor:</span> {r!.translator}
                </p>
              )}
              {r!.notes && (
                <details class="reprint-notes">
                  <summary class="reprint-notes-summary">
                    ¿Por qué se publicó en blog.elcokiin?
                    <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="reprint-notes-content">{r!.notes}</div>
                </details>
              )}
            </div>
          </div>
        )
      }



      {coverUrl && <img class="post-cover" src={coverUrl} alt={post.title} loading="eager" />}

            <div class="">
        <section class="p-1 md:p-4">
          <div class="prose prose-lg max-w-none prose-headings:bg-gradient-to-r prose-headings:from-[var(--heading-gradient-from)] prose-headings:to-[var(--heading-gradient-to)] prose-headings:bg-clip-text prose-headings:text-transparent">
              <div class="relative p-8 md:p-12 bg-[var(--content-bg)] rounded-2xl backdrop-blur-sm shadow-inner">
              <div class="absolute top-4 left-4 w-8 h-8 border-l-2 border-t-2 border-[var(--text)] opacity-30 rounded-tl-lg"></div>
              <div class="absolute top-4 right-4 w-8 h-8 border-r-2 border-t-2 border-[var(--text)] opacity-30 rounded-tr-lg"></div>
              <div class="absolute bottom-4 left-4 w-8 h-8 border-l-2 border-b-2 border-[var(--text)] opacity-30 rounded-bl-lg"></div>
              <div class="absolute bottom-4 right-4 w-8 h-8 border-r-2 border-b-2 border-[var(--text)] opacity-30 rounded-br-lg"></div>
              <div set:html={htmlContent}></div>
            </div>
          </div>
        </section>
      </div>
    </article>
  </main>
  <SiteFooter />
</BaseLayout>
