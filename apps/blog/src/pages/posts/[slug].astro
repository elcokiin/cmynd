---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import CoverImage from "../../components/CoverImage.astro";
import ReprintCard from "../../components/ReprintCard.astro";
import { loadPost } from "../../lib/load-post";
import { formatPublishedDate } from "../../lib/utils";
import { SITE } from "../../lib/config";

import "../../styles/global.css";

const cacheControl = "public, max-age=300, s-maxage=1800, stale-while-revalidate=7200";
Astro.response.headers.set("Cache-Control", cacheControl);

const slug = Astro.params.slug;

if (!slug) {
  return Astro.redirect("/");
}

const post = await loadPost(slug);

if (!post) {
  return Astro.redirect("/404");
}

const title = `${post.title} · ${SITE.title}`;
const description = `${post.author.name} · ${formatPublishedDate(post.publishedAt)}`;
const canonicalPath = `/posts/${post.slug}/`;

const reprint = post.type === "reprint" ? post.reprint : undefined;
const isReprint = reprint !== undefined;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <SiteHeader />
  <main class="post-main container">
    <article class="post-article">
      <h1>{post.title}</h1>
      {!isReprint && <p class="post-meta">{post.author.name} · {formatPublishedDate(post.publishedAt)}{post.estimatedReadTime ? ` · ${post.estimatedReadTime} min de lectura` : ''}</p>}

      {reprint && (
        <ReprintCard
          reprint={reprint}
          authorName={post.author.name}
          publishedAt={post.publishedAt}
          estimatedReadTime={post.estimatedReadTime}
        />
      )}

      {post.coverUrl && (
        <CoverImage
          coverUrl={post.coverUrl}
          title={post.title}
          coverImagePrompt={post.coverImage?.prompt}
          description={post.description}
        />
      )}

      <section class="post-content">
        <div class="post-content__inner">
          <div class="prose prose-lg max-w-none prose-headings:bg-linear-to-r prose-headings:from-(--heading-gradient-from) prose-headings:to-(--heading-gradient-to) prose-headings:bg-clip-text prose-headings:text-transparent">
            <div set:html={post.htmlContent}></div>
          </div>
        </div>
      </section>
    </article>
  </main>
  <SiteFooter />
</BaseLayout>
