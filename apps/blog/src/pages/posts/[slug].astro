---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { getPublishedDocumentBySlug, getPublicStorageUrl } from "../../lib/convex";
import { formatPublishedDate } from "../../lib/utils";
import { renderRichContent } from "../../lib/tiptap-render";
import { SITE } from "../../lib/config";

import "../../styles/global.css";

const cacheControl = "public, max-age=300, s-maxage=1800, stale-while-revalidate=7200";
Astro.response.headers.set("Cache-Control", cacheControl);

const slug = Astro.params.slug;

if (!slug) {
  return Astro.redirect("/");
}

const post = await getPublishedDocumentBySlug(slug);

if (!post) {
  return Astro.redirect("/404");
}

const coverUrl = post.coverImageId ? await getPublicStorageUrl(post.coverImageId) : undefined;
const htmlContent = renderRichContent(post.content);

const title = `${post.title} · ${SITE.title}`;
const description = `${post.author.name} · ${formatPublishedDate(post.publishedAt)}`;
const canonicalPath = `/posts/${post.slug}/`;

const r = post.type === "reprint" ? post.reprint : undefined;
const isReprint = r !== undefined;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <SiteHeader />
  <main class="post-main container">
    <article class="post-article">
      <h1>{post.title}</h1>
      {!isReprint && <p class="post-meta">{post.author.name} · {formatPublishedDate(post.publishedAt)}{post.estimatedReadTime ? ` · ${post.estimatedReadTime} min de lectura` : ''}</p>}
      {
        isReprint && (
          <div class="reprint-card">
            <span class="reprint-card__badge">Reimpresión</span>
            <div class="reprint-card__body">
              {r!.originalTitle && (
                <p class="reprint-card__title">
                  {r!.sourceUrl ? (
                    <a href={r!.sourceUrl} target="_blank" rel="noopener noreferrer">
                      <span class="reprint-card__title-text">“{r!.originalTitle}”</span>
                      <svg class="reprint-card__ext-link" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </a>
                  ) : (
                    <span class="reprint-card__title-text">“{r!.originalTitle}”</span>
                  )}
                </p>
              )}
              {(r!.originalAuthor || r!.originalDate) && (
                <p class="reprint-card__attribution">
                  {r!.originalAuthor && <span class="reprint-card__attribution-author">{r!.originalAuthor}</span>}
                  {r!.originalDate && <span class="reprint-card__attribution-date">{r!.originalDate}</span>}
                </p>
              )}
              <hr class="reprint-card__rule" aria-hidden="true" />
              <div class="reprint-card__meta">
                {post.author.name && <span class="reprint-card__field"><span class="reprint-card__label">Publicado por</span> {post.author.name}</span>}
                <span class="reprint-card__field">{formatPublishedDate(post.publishedAt)}</span>
                {post.estimatedReadTime && <span class="reprint-card__field">{post.estimatedReadTime} min de lectura</span>}
              </div>
              {r!.translator && (
                <p class="reprint-card__translator">
                  <span class="reprint-card__label">Traductor:</span> {r!.translator}
                </p>
              )}
              {r!.notes && (
                <details class="reprint-card__notes">
                  <summary class="reprint-card__notes-summary">
                    ¿Por qué se publicó en blog.elcokiin?
                    <svg class="reprint-card__chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="reprint-card__notes-content">{r!.notes}</div>
                </details>
              )}
            </div>
          </div>
        )
      }

      {
        coverUrl && (
          <figure class="post-cover group relative overflow-hidden rounded-lg bg-neutral-900" data-color-thief data-cover-url={coverUrl} data-prompt-text={post.coverImagePrompt || post.description || ''}>
            <img
              src={coverUrl}
              alt={post.title}
              loading="eager"
              class="w-full h-full object-contain"
              crossorigin="anonymous"
              data-color-thief-target
            />
            <div class="overlay absolute inset-0 opacity-0 group-hover:opacity-100 transition-all duration-500 ease-out bg-gradient-to-t from-black/100 via-black/70 to-transparent backdrop-blur-md flex flex-col justify-end">
              <button data-dismiss-overlay class="action-btn absolute top-3 right-3 z-10 dismiss-btn" title="Cerrar">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M18 6L6 18M6 6l12 12" />
                </svg>
              </button>
              <div class="text-white p-6 transform translate-y-8 group-hover:translate-y-0 transition-transform duration-500 ease-out">
                <h3 class="flex items-center text-2xl font-semibold mb-3">
                  {post.coverImagePrompt ? 'Prompt' : 'Descripción'}
                </h3>
                <p class="text-base leading-relaxed text-gray-100/90 line-clamp-4 mb-3">
                  {post.coverImagePrompt || post.description}
                </p>
                <p class="text-sm text-gray-400 mb-3" data-image-dimensions></p>
                <div class="h-0.5 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-700 delay-200" style="height: 2px; background: linear-gradient(to right, var(--dominant-color, #f87171) 0%, color-mix(in srgb, var(--dominant-color, #f87171) 50%, transparent) 60%, transparent 100%);"></div>
                <div class="overlay-actions flex items-center justify-end gap-4 mt-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-300">
                  <button class="action-btn" data-download title="Descargar imagen" style="color: var(--dominant-color, #f87171)">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                  </button>
                  <button class="action-btn" data-copy-image title="Copiar imagen" style="color: var(--dominant-color, #f87171)">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2" stroke-linecap="round" stroke-linejoin="round" stroke-width={2} />
                      <circle cx="8.5" cy="8.5" r="1.5" stroke-width={2} />
                      <polyline points="21 15 16 10 5 21" stroke-linecap="round" stroke-linejoin="round" stroke-width={2} />
                    </svg>
                  </button>
                  <button class="action-btn" data-copy-prompt title={post.coverImagePrompt ? 'Copiar prompt' : 'Copiar descripción'} style="color: var(--dominant-color, #f87171)">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-linecap="round" stroke-linejoin="round" stroke-width={2} />
                      <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-linecap="round" stroke-linejoin="round" stroke-width={2} />
                    </svg>
                  </button>
                </div>
              </div>
            </div>
            <div class="glow absolute inset-0 rounded-lg opacity-0 group-hover:opacity-20 transition-opacity duration-500 pointer-events-none" style="background: linear-gradient(to top, color-mix(in srgb, var(--dominant-color, #f87171) 20%, transparent) 0%, transparent 100%);"></div>
            <button data-restore-overlay class="restore-btn action-btn" title="Mostrar información" style="display: none; color: var(--dominant-color, #f87171); width: 3rem; height: 3rem; position: absolute; bottom: 1rem; right: 1rem;">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" stroke-linecap="round" stroke-linejoin="round" stroke-width={2} />
                <line x1="12" y1="16" x2="12" y2="12" stroke-linecap="round" stroke-linejoin="round" stroke-width={2} />
                <line x1="12" y1="8" x2="12.01" y2="8" stroke-linecap="round" stroke-linejoin="round" stroke-width={2} />
              </svg>
            </button>
          </figure>
        )
      }

      <script>
        import { applyDominantColor } from '../../lib/color-thief';
        import { copyText, copyImage, downloadImage } from '../../lib/clipboard';
        import { getImageDimensions } from '../../lib/image';

        const figure = document.querySelector<HTMLElement>('[data-color-thief]');
        const IMAGE_URL = figure?.getAttribute('data-cover-url') || '';
        const PROMPT_TEXT = figure?.getAttribute('data-prompt-text') || '';

        const img = document.querySelector<HTMLImageElement>('[data-color-thief-target]');
        if (img) {
          applyDominantColor(img);
        }

        const dimensionsEl = document.querySelector('[data-image-dimensions]');
        if (dimensionsEl && IMAGE_URL) {
          getImageDimensions(IMAGE_URL).then((dims) => {
            if (dims) {
              dimensionsEl.textContent = `${dims.width} × ${dims.height} px`;
            }
          });
        }

        const showFeedback = (btn: Element | null, success = true) => {
          if (!btn) return;
          const original = btn.innerHTML;
          btn.innerHTML = success
            ? '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>'
            : '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>';
          setTimeout(() => { btn.innerHTML = original; }, 2000);
        };

        const dismissOverlay = () => {
          if (!figure) return;
          figure.setAttribute('data-overlay-dismissed', '');
        };

        const restoreOverlay = () => {
          if (!figure) return;
          figure.removeAttribute('data-overlay-dismissed');
        };

        document.querySelector('[data-dismiss-overlay]')?.addEventListener('click', dismissOverlay);
        document.querySelector('[data-restore-overlay]')?.addEventListener('click', restoreOverlay);

        document.querySelector('[data-download]')?.addEventListener('click', async () => {
          const ok = Boolean(await downloadImage(IMAGE_URL));
          showFeedback(document.querySelector('[data-download]'), ok);
        });

        document.querySelector('[data-copy-image]')?.addEventListener('click', async () => {
          const ok = Boolean(await copyImage(IMAGE_URL));
          showFeedback(document.querySelector('[data-copy-image]'), ok);
        });

        document.querySelector('[data-copy-prompt]')?.addEventListener('click', async () => {
          if (!PROMPT_TEXT) return;
          const ok = await copyText(PROMPT_TEXT);
          if (ok) showFeedback(document.querySelector('[data-copy-prompt]'));
        });
      </script>

      <style>
        .action-btn {
          display: flex;
          align-items: center;
          justify-content: center;
          width: 2.5rem;
          height: 2.5rem;
          border-radius: 9999px;
          background: rgba(255, 255, 255, 0.1);
          backdrop-filter: blur(4px);
          border: 1px solid rgba(255, 255, 255, 0.2);
          cursor: pointer;
          transition: background 0.2s, transform 0.2s;
        }
        .action-btn:hover {
          background: rgba(255, 255, 255, 0.2);
          transform: scale(1.1);
        }

        .dismiss-btn {
          color: var(--destructive) !important;
          border-radius: 0.375rem;
          background: color-mix(in srgb, var(--destructive) 20%, transparent);
          border-color: color-mix(in srgb, var(--destructive) 30%, transparent);
          width: 2rem;
          height: 2rem;
        }
        .dismiss-btn:hover {
          background: color-mix(in srgb, var(--destructive) 45%, transparent) !important;
          transform: none !important;
        }

        [data-overlay-dismissed] .overlay {
          opacity: 0 !important;
          pointer-events: none;
        }
        [data-overlay-dismissed] .glow {
          opacity: 0 !important;
        }
        [data-overlay-dismissed] [data-restore-overlay] {
          display: flex !important;
          z-index: 10;
          background: rgba(0, 0, 0, 0.6);
          backdrop-filter: blur(4px);
          border: 1px solid rgba(255, 255, 255, 0.15);
        }
        [data-overlay-dismissed] [data-restore-overlay]:hover {
          background: rgba(0, 0, 0, 0.8);
          transform: scale(1.15);
        }
      </style>

      <section class="post-content">
        <div class="post-content__inner">
          <div class="prose prose-lg max-w-none prose-headings:bg-gradient-to-r prose-headings:from-[var(--heading-gradient-from)] prose-headings:to-[var(--heading-gradient-to)] prose-headings:bg-clip-text prose-headings:text-transparent">
            <div set:html={htmlContent}></div>
          </div>
        </div>
      </section>
    </article>
  </main>
  <SiteFooter />
</BaseLayout>
