---
import type { BlogPostListItem } from "../lib/types";
import PostCard from "./PostCard.astro";

type Props = {
  posts: BlogPostListItem[];
};

const { posts } = Astro.props;

const sections: { type: "featured" | "grid-medium" | "grid-large"; posts: BlogPostListItem[] }[] = [];

let remaining = [...posts];

if (remaining.length > 0) {
  sections.push({ type: "featured", posts: [remaining.shift()!] });
}

while (remaining.length > 0) {
  const medium = remaining.splice(0, 3);
  const large = remaining.splice(0, 2);

  if (medium.length > 0) sections.push({ type: "grid-medium", posts: medium });
  if (large.length > 0) sections.push({ type: "grid-large", posts: large });
}
---

<div class="blog-grid-container flex flex-col gap-8 md:gap-12 w-full py-8">
  {sections.map((section) => (
    section.type === "featured" ? (
      <section aria-label="Featured post" class="w-full">
        <PostCard post={section.posts[0]} type="featured" />
      </section>
    ) : (
      <section aria-label={`${section.type} posts`} class={`grid ${section.type === "grid-medium" ? "grid-cols-1 md:grid-cols-2 lg:grid-cols-3" : "grid-cols-1 md:grid-cols-2"} gap-6 md:gap-8`}>
        {section.posts.map((post) => (
          <PostCard post={post} type={section.type} />
        ))}
      </section>
    )
  ))}
</div>
