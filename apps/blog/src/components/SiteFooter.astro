---
let year = new Date().getFullYear().toString();
let lastUpdateDate = "";

try {
  // Fetch the latest commit from the GitHub API
  // Using the repository you mentioned: elcokiin/cmynd
  const response = await fetch("https://api.github.com/repos/elcokiin/cmynd/commits?per_page=1");
  
  if (response.ok) {
    const data = await response.json();
    const commitDate = data[0].commit.author.date;
    const dateObj = new Date(commitDate);
    
    year = dateObj.getFullYear().toString();
    lastUpdateDate = dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }
} catch (e) {
  console.error("Failed to get git commit date:", e);
}

// Texts defaulting to Spanish since this is the primary language used in the site context
const texts = {
  subtitle: "Desarrollador Full Stack y Emprendedor Entusiasta",
  copyright: "",
  madeWith: "Hecho con",
  inCountry: "en Colombia",
  tagline: "Always learning, always growing",
};
---

