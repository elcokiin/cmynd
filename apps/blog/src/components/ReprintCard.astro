---
import type { ReprintData } from "@elcokiin/backend/lib/types/documents";
import { formatPublishedDate } from "../lib/utils";

type Props = {
  reprint: ReprintData;
  authorName: string;
  publishedAt: number;
  estimatedReadTime?: number;
};

const { reprint, authorName, publishedAt, estimatedReadTime } = Astro.props;
---

<div class="reprint-card">
  <span class="reprint-card__badge">Reimpresión</span>
  <div class="reprint-card__body">
    {reprint.originalTitle && (
      <p class="reprint-card__title">
        {reprint.sourceUrl ? (
          <a href={reprint.sourceUrl} target="_blank" rel="noopener noreferrer">
            <span class="reprint-card__title-text">“{reprint.originalTitle}”</span>
            <svg class="reprint-card__ext-link" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        ) : (
          <span class="reprint-card__title-text">“{reprint.originalTitle}”</span>
        )}
      </p>
    )}
    {(reprint.originalAuthor || reprint.originalDate) && (
      <p class="reprint-card__attribution">
        {reprint.originalAuthor && <span class="reprint-card__attribution-author">{reprint.originalAuthor}</span>}
        {reprint.originalDate && <span class="reprint-card__attribution-date">{reprint.originalDate}</span>}
      </p>
    )}
    <hr class="reprint-card__rule" aria-hidden="true" />
    <div class="reprint-card__meta">
      {authorName && <span class="reprint-card__field"><span class="reprint-card__label">Publicado por</span> {authorName}</span>}
      <span class="reprint-card__field">{formatPublishedDate(publishedAt)}</span>
      {estimatedReadTime && <span class="reprint-card__field">{estimatedReadTime} min de lectura</span>}
    </div>
    {reprint.translator && (
      <p class="reprint-card__translator">
        <span class="reprint-card__label">Traductor:</span> {reprint.translator}
      </p>
    )}
    {reprint.notes && (
      <details class="reprint-card__notes">
        <summary class="reprint-card__notes-summary">
          ¿Por qué se publicó en blog.elcokiin?
          <svg class="reprint-card__chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="reprint-card__notes-content">{reprint.notes}</div>
      </details>
    )}
  </div>
</div>
