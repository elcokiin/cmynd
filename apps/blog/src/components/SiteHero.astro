---
// SiteHero.astro
import { Atmosphere } from "@elcokiin/ui/atmosphere";
import { getRandomPhrase } from "../lib/phrases";

const { phrase, author } = getRandomPhrase();
---

<Atmosphere client:load className="relative flex flex-col items-center justify-center min-h-[60vh] py-10 sm:py-24 sm:px-8 md:py-32 overflow-hidden">
  <div class="relative z-10 flex flex-col items-center">
    <h2 class="hero-title cursor-pointer font-bold text-4xl text-[var(--primary-blue)] dark:text-[var(--primary-aquamarine)] sm:text-6xl lg:text-5xl mb-6">
      <a href="https://elcokiin.my">
        Diego Tenjo
      </a>
    </h2>

    <p
      class="hero-description w-4/5 text-md leading-relaxed font-serif text-center px-12 py-4 rounded-md sm:text-2xl lg:text-xl text-zinc-800 dark:text-zinc-200"
    >
      "{phrase}" <br/> <span class="text-sm opacity-80 mt-2 block">- {author}</span>
    </p>
  </div>
</Atmosphere>

<script>
  import gsap from 'gsap';
  import SplitType from 'split-type';

  const initAnimations = () => {
    const titleLink = document.querySelector('.hero-title a');
    const description = document.querySelector('.hero-description');

    if (titleLink) {
      const splitTitle = new SplitType(titleLink as HTMLElement, { types: 'chars', tagName: 'span' });
      // Reset first to avoid issues with view transitions
      gsap.set(splitTitle.chars, { clearProps: "all" });
      gsap.from(splitTitle.chars, {
        y: 50,
        opacity: 0,
        duration: 1,
        stagger: 0.05,
        ease: 'back.out(1.7)'
      });
    }

    if (description) {
      const splitDesc = new SplitType(description as HTMLElement, { types: 'words', tagName: 'span' });
      gsap.set(splitDesc.words, { clearProps: "all" });
      gsap.from(splitDesc.words, {
        y: 20,
        opacity: 0,
        duration: 0.8,
        stagger: 0.02,
        ease: 'power2.out',
        delay: 0.3
      });
    }
  };

  const setup = () => {
    initAnimations();
  };

  // Run on initial load and view transitions
  document.addEventListener('astro:page-load', setup);
  
  // Run initially for standard loads
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    setTimeout(setup, 0);
  } else {
    document.addEventListener('DOMContentLoaded', setup);
  }
</script>

<style>
  .hero-title a {
    position: relative;
    display: inline-block;
  }
  
  .hero-title a::after {
    content: '';
    position: absolute;
    width: 100%;
    transform: scaleX(0);
    height: 3px;
    bottom: -4px;
    left: 0;
    background-color: currentColor;
    transform-origin: bottom right;
    transition: transform 0.25s ease-out;
  }
  
  .hero-title a:hover::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }

  /* Ensure split-type elements display inline correctly */
  :global(.word), :global(.char) {
    display: inline-block;
  }
</style>
