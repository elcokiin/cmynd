---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
---

<header 
  id="site-header" 
  class="z-10 fixed top-0 flex items-center justify-between p-2 w-full sm:p-4 md:px-20 text-white bg-primary-blue border-b border-transparent transition-all duration-255"
>
  <div class="flex items-center w-32 justify-between sm:w-40">
    <a href="/" data-astro-prefetch>
      <figure class="w-14 h-14 rounded-full object-cover sm:w-20 sm:h-20 lg:w-14 lg:h-14">
        <Image src={logo} alt="elcokiin logo" class="object-cover rounded-full w-full h-full" />
      </figure>
    </a>
    <a href="/" class="font-bold sm:text-2xl" data-astro-prefetch>
      Inicio
    </a>
  </div>

  <div class="flex items-center gap-4">
    <a 
      href="https://elcokiin.my" 
      target="_blank"
      rel="noopener noreferrer"
      id="header-author-name" 
      class="animated-underline font-bold text-xl text-white opacity-0 pointer-events-none transition-opacity duration-300 hidden sm:block"
      style="--underline-height: 2px; --underline-bottom: -2px;"
    >
      Diego Tenjo
    </a>
    <div class="hidden sm:flex justify-center items-center gap-4">
      {/* TODO: Add ToogleTheme and ToogleLanguage components when available */}
    </div>
    {/* Mobile Menu Button */}
    <button class="w-8 h-8 sm:hidden flex items-center justify-center text-white" aria-label="Menu" id="mobile-menu-btn">
      <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 512 512" height="26" width="26" xmlns="http://www.w3.org/2000/svg">
        <path d="M32 96v64h448V96H32zm0 128v64h448v-64H32zm0 128v64h448v-64H32z"></path>
      </svg>
    </button>
  </div>
</header>

<script>
  function setupHeaderScroll() {
    const header = document.getElementById('site-header');
    
    const handleScroll = () => {
      if (!header) return;
      
      const scrolled = window.scrollY;
      const threshold = window.innerHeight * 0.4;
      
      if (scrolled > threshold) {
        header.classList.add('backdrop-blur-md', 'bg-primary-blue/80', 'border-gray-700');
        header.classList.remove('bg-primary-blue', 'border-transparent');
      } else {
        header.classList.remove('backdrop-blur-md', 'bg-primary-blue/80');
        header.classList.add('bg-primary-blue', 'border-transparent');
      }
    };

    window.addEventListener('scroll', handleScroll);
    // Initial check
    handleScroll();
  }

  // Setup on initial load
  setupHeaderScroll();
  
  // Setup on Astro view transitions (if used)
  document.addEventListener('astro:page-load', setupHeaderScroll);
</script>
